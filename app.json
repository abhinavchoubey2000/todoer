{
	"expo": {
		"name": "Todoer",
		"slug": "todoer",
		"version": "1.0.0",
		"orientation": "portrait",
		"scheme": "todoer",
		"userInterfaceStyle": "automatic",
		"icon": "./assets/images/todoer-logo.png",
		"backgroundColor": "#050B14",
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"package": "com.abhinav.todoer",
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/todoer-logo.png",
				"backgroundColor": "#050B14"
			},
			"predictiveBackGestureEnabled": false
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/todoer-logo.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"backgroundColor": "#050B14",
					"image": "./assets/images/todoer-logo.png",
					"imageWidth": 180
				}
			],
			"expo-image",
			"expo-web-browser"
		],
		"experiments": {
			"typedRoutes": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "f98329eb-a2a6-41c8-b1b7-2173bf9a5669"
			}
		},
		"runtimeVersion": {
			"policy": "appVersion"
		},
		"updates": {
			"url": "https://u.expo.dev/f98329eb-a2a6-41c8-b1b7-2173bf9a5669"
		}
	}
}
